# ─────────────────────────────────────────
# PostPageX — Environment Variables
# Copy this file to .env and fill in values
# NEVER commit .env to version control
# ─────────────────────────────────────────

# ── SERVER ──
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://127.0.0.1:5500

# ── DATABASE (PostgreSQL) ──
# Get from Railway: railway.app → New Project → PostgreSQL
DATABASE_URL=postgresql://postgres:ZPGkaEFLLVtuYCEmqInIsCfiYyzhfWND@maglev.proxy.rlwy.net:39615/railway
DB_SSL=true  # set to true on Railway/Render production

# ── REDIS ──
# Get from Railway: New Service → Redis
REDIS_URL=redis://default:wRiquQZOCDZcrsdxIiyRpLzHTiSvayJJ@redis.railway.internal:6379

# ── JWT ──
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=53a30d65669faa40c4d163f066d529b37e9949df96adcf6ef001e769fbcf97377b844cd83f398b8355f4a5baa6b1beda77e84025dce52aefbfeb1c10e347930c
JWT_EXPIRES_IN=7d

# ── SESSION ──
SESSION_SECRET=another_random_secret_for_sessions_minimum_32_chars

# ── GOOGLE OAUTH ──
# Get from: console.cloud.google.com → APIs → Credentials → OAuth 2.0
# Authorized redirect URI: http://localhost:4000/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback

# ── FACEBOOK / META GRAPH API ──
# Get from: developers.facebook.com → Your App → Settings → Basic
# Redirect URI: http://localhost:4000/auth/facebook/callback
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_CALLBACK_URL=http://localhost:4000/auth/facebook/callback
FACEBOOK_GRAPH_VERSION=v19.0

# ── ENCRYPTION (for Facebook tokens) ──
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=66e1522b477e02754012214dee2761ee9bf4455ebdc1c0235d8b768251dd5fde

# ── FILE UPLOADS (optional: use S3 for production) ──
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=100

# ── EMAIL (optional: for notifications) ──
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=hello@postpagex.com
# SMTP_PASS=your_app_password
# EMAIL_FROM=PostPageX <hello@postpagex.com>
