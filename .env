# ─────────────────────────────────────────
# PostPageX — Environment Variables
# Copy this file to .env and fill in values
# NEVER commit .env to version control
# ─────────────────────────────────────────

# ── SERVER ──
NODE_ENV=production  
PORT=4000
FRONTEND_URL=https://postpagex1.vercel.app/

# ── DATABASE (PostgreSQL) ──
# Get from Railway: railway.app → New Project → PostgreSQL
DATABASE_URL=postgresql://postgres:ZPGkaEFLLVtuYCEmqInIsCfiYyzhfWND@postgres.railway.internal:5432/railway
DB_SSL=true  # set to true on Railway/Render production

# ── REDIS ──
# Get from Railway: New Service → Redis
REDIS_URL=redis://default:wRiquQZOCDZcrsdxIiyRpLzHTiSvayJJ@redis.railway.internal:6379

# ── JWT ──
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=5520d4a1c2226422e5a94c878b87ea1e2ad907e94acf0e8878e7a17f3a689e66
JWT_EXPIRES_IN=7d

# ── SESSION ──
SESSION_SECRET=15020ff26c44f6adc24b75a8c8cee0b44521e8e34d6966a5edb4de8327f15919

# ── GOOGLE OAUTH ──
# Get from: console.cloud.google.com → APIs → Credentials → OAuth 2.0
# Authorized redirect URI: http://localhost:4000/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback

# ── FACEBOOK / META GRAPH API ──
# Get from: developers.facebook.com → Your App → Settings → Basic
# Redirect URI: http://localhost:4000/auth/facebook/callback
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_CALLBACK_URL=http://localhost:4000/auth/facebook/callback
FACEBOOK_GRAPH_VERSION=v19.0

# ── ENCRYPTION (for Facebook tokens) ──
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=66e1522b477e02754012214dee2761ee9bf4455ebdc1c0235d8b768251dd5fde

# ── FILE UPLOADS (optional: use S3 for production) ──
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=100

# ── EMAIL (optional: for notifications) ──
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=hello@postpagex.com
# SMTP_PASS=your_app_password
# EMAIL_FROM=PostPageX <hello@postpagex.com>
